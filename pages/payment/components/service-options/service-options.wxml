<view class="service-options">
  <block wx:for="{{options}}" wx:key="key">
    <view
      class="service-options__item {{item.key === selectedKey ? 'service-options__item--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onOptionTap"
    >
      <view class="service-options__radio {{item.key === selectedKey ? 'service-options__radio--active' : ''}}">
        <van-icon wx:if="{{item.key === selectedKey}}" name="success" size="14px" color="#ffffff" />
      </view>

      <view class="service-options__main">
        <view class="service-options__title-row">
          <text class="service-options__title">{{item.title}}</text>
          <text wx:if="{{item.badge}}" class="service-options__badge">{{item.badge}}</text>
        </view>
        <text class="service-options__desc">{{item.desc}}</text>
      </view>

      <view class="service-options__aside">
        <view class="service-options__price-row">
          <text class="service-options__price-label">一口价</text>
          <view class="service-options__price-value">
            <text class="service-options__price-number">{{item.price}}</text>
            <text class="service-options__price-unit">元</text>
          </view>
        </view>
        <text wx:if="{{item.promoText}}" class="service-options__promo">{{item.promoText}}</text>
      </view>
    </view>
  </block>

  <view class="service-options__toggle-row">
    <block wx:for="{{toggles}}" wx:key="key">
      <view class="service-options__toggle" data-key="{{item.key}}" bindtap="onToggleTap">
        <view class="service-options__checkbox {{item.checked ? 'service-options__checkbox--active' : ''}}">
          <van-icon wx:if="{{item.checked}}" name="success" size="12px" color="#ffffff" />
        </view>
        <text class="service-options__toggle-label">{{item.label}}</text>
      </view>
    </block>
  </view>
</view>
