<view class="payment-bar" style="padding-bottom: {{safeBottom}}px;">
  <view class="payment-bar__shell">
    <view class="payment-bar__schedule" bindtap="onScheduleTap">
      <view class="payment-bar__schedule-icon">
        <van-icon class="payment-bar__schedule-icon-mark" name="clock-o" size="16px" color="currentColor" />
      </view>
      <text class="payment-bar__schedule-label">{{scheduleLabel}}</text>
      <van-icon class="payment-bar__schedule-arrow" name="arrow" size="14px" color="currentColor" />
    </view>

    <view class="payment-bar__action" bindtap="onPayTap">
      <text class="payment-bar__action-price">{{payPrice}}元</text>
      <text class="payment-bar__action-label">{{payLabel}}</text>
    </view>
  </view>
</view>
