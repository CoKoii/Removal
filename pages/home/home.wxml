<view class="home-page">
  <view class="home__header">
    <home-top-banner
      city="{{city}}"
      serviceLabel="{{service.label}}"
      safeTop="{{headerSafeTop}}"
      capsuleHeight="{{capsuleHeight}}"
      capsuleSpaceWidth="{{capsuleSpaceWidth}}"
    />
  </view>

  <scroll-view class="home__scroll" scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}">
    <view class="home__content">
      <view class="home__section">
        <home-vehicle-card
          vehicleTypes="{{service.vehicleTypes}}"
          selectedTypeIndex="{{activeVehicleTypeIndex}}"
          bind:selectionchange="onVehicleChange"
        />
      </view>

      <view class="home__section">
        <home-order-card
          order="{{service.orderCard}}"
          selectedDropoffLabel="{{selectedDropoffLabel}}"
          bind:dropoffchange="onDropoffChange"
        />
      </view>

      <view class="home__section home__section--process">
        <home-process-flow flow="{{service.processFlow}}" />
      </view>

      <view class="home__section">
        <view class="home__assurance">
          <text class="home__assurance-summary">{{service.complianceSummary}}</text>
        </view>
      </view>

      <view class="home__section">
        <home-shortcut-grid items="{{service.quickActions}}" bind:itemtap="onShortcutTap" />
      </view>

      <view class="home__section home__section--feedback" bindtap="onFeedbackTap">
        <view class="home__feedback">
          <text class="home__feedback-text">{{service.processFlow.feedbackText}}</text>
          <van-icon class="home__feedback-icon" name="arrow" size="14px" color="currentColor" />
        </view>
      </view>
    </view>
  </scroll-view>
</view>
