<view class="home-page">
  <view class="home__header">
    <home-top-banner
      city="{{city}}"
      serviceLabel="{{service.label}}"
      safeTop="{{headerSafeTop}}"
      capsuleHeight="{{capsuleHeight}}"
      capsuleSpaceWidth="{{capsuleSpaceWidth}}"
    />
  </view>

  <scroll-view class="home__scroll" scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}">
    <view class="home__content">
      <view class="home__section">
        <home-vehicle-card vehicleTypes="{{service.vehicleTypes}}" />
      </view>

      <view class="home__section">
        <home-order-card order="{{service.orderCard}}" />
      </view>

      <view class="home__section">
        <home-shortcut-grid items="{{service.quickActions}}" bind:itemtap="onShortcutTap" />
      </view>

      <view class="home__section home__section--promo">
        <home-promo-row cards="{{service.promoCards}}" bind:cardtap="onPromoTap" />
      </view>
    </view>
  </scroll-view>
</view>
