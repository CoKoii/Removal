<view class="mine-page">
  <view class="mine__content">
    <view class="mine__hero">
      <text class="mine__eyebrow">My Removal</text>
      <text class="mine__title">我的服务</text>
      <text class="mine__desc">先把页面结构补齐到统一规范，后续功能可以继续在卡片区块上扩展。</text>
    </view>

    <view class="mine__card">
      <view class="mine__card-head">
        <text class="mine__card-title">常用入口</text>
        <text class="mine__card-tip">{{quickLinks.length}}项</text>
      </view>

      <block wx:for="{{quickLinks}}" wx:key="key">
        <view class="mine__row {{index !== quickLinks.length - 1 ? 'mine__row--border' : ''}}">
          <view class="mine__row-copy">
            <text class="mine__row-label">{{item.label}}</text>
            <text class="mine__row-value">{{item.value}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="mine__card mine__card--tips">
      <view class="mine__card-head">
        <text class="mine__card-title">页面约束</text>
      </view>

      <block wx:for="{{tips}}" wx:key="*this">
        <view class="mine__tip">
          <view class="mine__tip-dot"></view>
          <text class="mine__tip-text">{{item}}</text>
        </view>
      </block>
    </view>
  </view>
</view>
