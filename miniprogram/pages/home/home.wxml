<view class="home-page">
  <view class="home__header">
    <home-top-banner
      city="{{city}}"
      tabs="{{serviceTabs}}"
      activeTabKey="{{activeServiceKey}}"
      safeTop="{{headerSafeTop}}"
      capsuleHeight="{{capsuleHeight}}"
      capsuleSpaceWidth="{{capsuleSpaceWidth}}"
      bind:tabchange="onServiceChange"
    />
  </view>

  <scroll-view class="home__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="home__content">
      <block wx:if="{{activeServiceKey === 'cargo'}}">
        <view class="home__section">
          <home-vehicle-card
            heroWord="{{heroWord}}"
            heroBadge="{{heroBadge}}"
            rows="{{vehicleRows}}"
            moreTransportLabel="{{moreTransportLabel}}"
            transportTags="{{transportTags}}"
          />
        </view>

        <view class="home__section">
          <home-order-card
            pickupBadge="{{pickupBadge}}"
            pickupTitle="{{pickupTitle}}"
            discountText="{{discountText}}"
            dropoffPrimaryText="{{dropoffPrimaryText}}"
            dropoffSecondaryText="{{dropoffSecondaryText}}"
            viaPointLabel="{{viaPointLabel}}"
            bind:pickuptap="onPickupTap"
            bind:entrytap="onOrderEntryTap"
            bind:viatap="onViaPointTap"
          />
        </view>

        <view class="home__section">
          <home-shortcut-grid items="{{quickActions}}" bind:itemtap="onShortcutTap" />
        </view>

        <view class="home__section home__section--promo">
          <home-promo-row cards="{{promoCards}}" bind:cardtap="onPromoTap" />
        </view>
      </block>

      <view wx:else class="home__placeholder">
        <view class="home__placeholder-title">{{activeServiceLabel}}</view>
      </view>
    </view>
  </scroll-view>
</view>
